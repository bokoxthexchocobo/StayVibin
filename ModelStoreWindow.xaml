<Window x:Class="StayVibin.ModelStoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Model Store" Height="680" Width="840"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FontFamily="Segoe UI" FontSize="14">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Model Store"
                       Foreground="{StaticResource Text}" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="Install and remove local Ollama models with a click - no PowerShell needed."
                       Foreground="{StaticResource TextDim}" TextWrapping="Wrap" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Disk summary + actions -->
        <Border Grid.Row="1" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}"
                BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="DiskSummary" Grid.Column="0" VerticalAlignment="Center"
                           Foreground="{StaticResource Text}" TextWrapping="Wrap"
                           Text="Reading installed models..."/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="GuideButton" Content="VRAM guide" Style="{StaticResource FlatButton}"
                            Padding="10,5" Click="OnOpenGuide"
                            ToolTip="See recommended models by VRAM tier"/>
                    <Button x:Name="RefreshButton" Content="Refresh" Style="{StaticResource FlatButton}"
                            Padding="10,5" Margin="8,0,0,0" Click="OnRefresh"
                            ToolTip="Re-scan installed models and disk usage"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Install any model by name -->
        <Border Grid.Row="2" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}"
                BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Install by name" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="InstallNameBox" Grid.Column="1" Style="{StaticResource DarkInput}"
                         VerticalAlignment="Center"
                         KeyDown="OnInstallNameKeyDown"
                         ToolTip="Type any Ollama tag, e.g. qwen3:14b"/>
                <Button x:Name="InstallByNameButton" Grid.Column="2" Content="Install"
                        Style="{StaticResource AccentButton}" MinWidth="90" Margin="10,0,0,0"
                        Click="OnInstallByName"/>
            </Grid>
        </Border>

        <!-- Progress (shown only while a pull is running) -->
        <Border x:Name="ProgressPanel" Grid.Row="3" Visibility="Collapsed"
                Background="{StaticResource PanelAlt}" BorderBrush="{StaticResource Border}"
                BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="ProgressText" Foreground="{StaticResource Text}"
                               Text="Working..." Margin="0,0,0,7"/>
                    <ProgressBar x:Name="ProgressBarCtl" Style="{StaticResource UsageBar}" Height="9"/>
                </StackPanel>
                <Button x:Name="StopInstallButton" Grid.Column="1" Content="Stop"
                        Style="{StaticResource DangerButton}" Padding="14,6" Margin="12,0,0,0"
                        VerticalAlignment="Center" Visibility="Collapsed" Click="OnStopInstall"
                        ToolTip="Cancel the current download"/>
            </Grid>
        </Border>

        <!-- Filters for the catalog -->
        <Border Grid.Row="4" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}"
                BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Filter" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="SearchBox" Grid.Column="1" Style="{StaticResource DarkInput}"
                         VerticalAlignment="Center" TextChanged="OnFilterChanged"
                         ToolTip="Search the catalog by name or description"/>
                <ComboBox x:Name="CategoryFilter" Grid.Column="2" MinWidth="130" Margin="10,0,0,0"
                          VerticalAlignment="Center" SelectedIndex="0"
                          SelectionChanged="OnFilterChanged"
                          ToolTip="Show only one kind of model">
                    <ComboBoxItem Content="All categories"/>
                    <ComboBoxItem Content="General"/>
                    <ComboBoxItem Content="Coding"/>
                    <ComboBoxItem Content="Reasoning"/>
                    <ComboBoxItem Content="Vision"/>
                </ComboBox>
                <ComboBox x:Name="AccuracyFilter" Grid.Column="3" MinWidth="135" Margin="10,0,0,0"
                          VerticalAlignment="Center" SelectedIndex="0"
                          SelectionChanged="OnFilterChanged"
                          ToolTip="Filter by how accurate the model is for real coding">
                    <ComboBoxItem Content="Any accuracy"/>
                    <ComboBoxItem Content="Fair or better"/>
                    <ComboBoxItem Content="Good or better"/>
                    <ComboBoxItem Content="Top local only"/>
                </ComboBox>
                <CheckBox x:Name="RecommendedOnly" Grid.Column="4" Content="Recommended only"
                          Foreground="{StaticResource Text}" VerticalAlignment="Center" Margin="14,0,0,0"
                          Checked="OnFilterChanged" Unchecked="OnFilterChanged"
                          ToolTip="Show only the models we recommend for agentic coding"/>
            </Grid>
        </Border>

        <!-- Lists -->
        <ScrollViewer x:Name="ContentScroller" Grid.Row="5" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Installed" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                <TextBlock x:Name="NoneInstalled" Text="No models installed yet. Install one below."
                           Foreground="{StaticResource TextDim}" Visibility="Collapsed" Margin="2,0,0,8"/>
                <ItemsControl x:Name="InstalledList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" CornerRadius="8" Padding="12,9" Margin="0,0,0,7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{StaticResource Text}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <Border CornerRadius="4" Padding="6,1" Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Background="{Binding AccuracyBrush}">
                                            <TextBlock Text="{Binding AccuracyText}" Foreground="White"
                                                       FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Background="{StaticResource Accent}" CornerRadius="4"
                                                Padding="6,1" Margin="6,0,0,0" VerticalAlignment="Center"
                                                Visibility="{Binding RecommendedVisibility}">
                                            <TextBlock Text="Recommended" Foreground="White"
                                                       FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding SizeText}"
                                               Foreground="{StaticResource TextDim}" VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    <Button Grid.Column="2" Content="Remove" Style="{StaticResource DangerButton}"
                                            Padding="12,5" Tag="{Binding Name}" Click="OnRemoveClick"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Available to install" Style="{StaticResource SectionHeader}"/>
                <TextBlock Text="Grouped by recommended VRAM. Going over a tier is fine - it spills into system RAM and just runs slower."
                           Foreground="{StaticResource TextDim}" FontSize="12" TextWrapping="Wrap"
                           Margin="2,0,0,4"/>
                <TextBlock TextWrapping="Wrap" FontSize="12" Margin="2,0,0,6"
                           Foreground="{StaticResource TextDim}">
                    <Run Text="Heads up: even the best local model is less accurate than paid cloud tools (Cursor, Claude, Codex). Bigger models get closest. Each model shows an accuracy badge -"/>
                    <Run Text=" Top local accuracy" Foreground="{StaticResource Ok}" FontWeight="SemiBold"/>
                    <Run Text="/"/>
                    <Run Text="Good" Foreground="{StaticResource Ok}" FontWeight="SemiBold"/>
                    <Run Text=" are best for real coding,"/>
                    <Run Text=" Fair" Foreground="{StaticResource Warn}" FontWeight="SemiBold"/>
                    <Run Text="/"/>
                    <Run Text="Basic" Foreground="{StaticResource Warn}" FontWeight="SemiBold"/>
                    <Run Text=" need supervision, and"/>
                    <Run Text=" Chat only" Foreground="{StaticResource Err}" FontWeight="SemiBold"/>
                    <Run Text=" are not coding agents."/>
                </TextBlock>
                <ItemsControl x:Name="CatalogList">
                    <ItemsControl.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource Accent}"
                                               FontSize="13" FontWeight="SemiBold" Margin="0,10,0,6"/>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ItemsControl.GroupStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" CornerRadius="8" Padding="12,9" Margin="0,0,0,7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Border CornerRadius="4" Padding="6,1" Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Background="{Binding AccuracyBrush}">
                                                <TextBlock Text="{Binding AccuracyText}" Foreground="White"
                                                           FontSize="10" FontWeight="SemiBold"/>
                                            </Border>
                                            <Border Background="{StaticResource Accent}" CornerRadius="4"
                                                    Padding="6,1" Margin="6,0,0,0" VerticalAlignment="Center"
                                                    Visibility="{Binding RecommendedVisibility}">
                                                <TextBlock Text="Recommended" Foreground="White"
                                                           FontSize="10" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Note}" Foreground="{StaticResource TextDim}"
                                                   FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Grid Grid.Column="1">
                                        <Button Content="Install" Style="{StaticResource AccentButton}"
                                                Padding="14,5" Tag="{Binding Name}" Click="OnInstallClick"
                                                Visibility="{Binding InstallVisibility}"/>
                                        <TextBlock Text="Installed" Foreground="{StaticResource Ok}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Visibility="{Binding InstalledVisibility}"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Close" Style="{StaticResource AccentButton}" MinWidth="90" Click="OnClose"/>
        </StackPanel>
    </Grid>
</Window>
