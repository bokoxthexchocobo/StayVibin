<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>StayVibin</AssemblyName>
    <RootNamespace>StayVibin</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>stayvibin.ico</ApplicationIcon>
    <Version>0.1.0</Version>
    <Product>StayVibin</Product>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="Assets\stayvibin.png" />
  </ItemGroup>

</Project>
