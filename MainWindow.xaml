<Window x:Class="StayVibin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:StayVibin.Models"
        xmlns:ae="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="StayVibin" Height="760" Width="1080"
        Icon="Assets/stayvibin.png"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="14">

    <Window.Resources>
        <!-- Pulses the status dot while the agent is working (secondary activity cue). -->
        <Storyboard x:Key="DotPulseSb" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="StatusDot"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.25" Duration="0:0:0.7"/>
        </Storyboard>

        <!--
          Spinner inside the Start/Stop button: rotates a small arc while the agent
          is working. Started/stopped from code (SetActivity) so it only spins while
          working. This is the primary "agent working" cue.
        -->
        <Storyboard x:Key="ButtonSpinSb" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ButtonSpinner"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360" Duration="0:0:0.85"/>
        </Storyboard>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="140"/>
            <RowDefinition Height="Auto"/>
            <!-- Bottom dock. Auto by default so the collapsed Server log sits flush
                 with the window bottom (no gap); switched to a resizable height in
                 code when the log is expanded. -->
            <RowDefinition x:Name="BottomDockRow" Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top bar + stats strip -->
        <StackPanel Grid.Row="0">
            <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}"
                    BorderThickness="0,0,0,1" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Live agent status, centered in the top bar's flexible middle -->
                    <TextBlock x:Name="StatusText" Grid.Column="1" Text="Stopped"
                               Foreground="{StaticResource TextDim}" VerticalAlignment="Center"
                               HorizontalAlignment="Center" FontSize="13"/>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="11" Height="11" Fill="{StaticResource Err}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Stay" Foreground="{StaticResource Text}" FontSize="18"
                                   FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Vibin" Foreground="{StaticResource Accent}" FontSize="18"
                                   FontWeight="SemiBold" Margin="2,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Model" Foreground="{StaticResource TextDim}" FontSize="12"
                                   VerticalAlignment="Center" Margin="16,0,8,0"/>
                        <ComboBox x:Name="ModelCombo" Style="{StaticResource DarkCombo}"
                                  MinWidth="190" VerticalAlignment="Center"
                                  SelectionChanged="OnModelSelected"
                                  ItemContainerStyle="{StaticResource ModelComboItem}"
                                  ToolTip="Models detected from your local Ollama">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button x:Name="RefreshModelsButton" Content="&#x21BB;"
                                Style="{StaticResource FlatButton}" Padding="9,3" FontSize="14"
                                Margin="6,0,0,0" VerticalAlignment="Center"
                                Click="OnRefreshModels"
                                ToolTip="Re-scan Ollama for installed models"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="ModelStoreButton" Content="Store" Style="{StaticResource FlatButton}"
                                Click="OnModelStore" Margin="0,0,8,0"
                                ToolTip="Install or remove local models with one click"/>
                        <Button x:Name="HistoryToggle" Content="Chats" Style="{StaticResource FlatButton}"
                                Click="OnToggleHistory" Margin="0,0,8,0"
                                ToolTip="Show/hide the conversation history"/>
                        <Button x:Name="ExplorerToggle" Content="Files" Style="{StaticResource FlatButton}"
                                Click="OnToggleExplorer" Margin="0,0,8,0"
                                ToolTip="Show/hide the file explorer"/>
                        <Button x:Name="SettingsButton" Content="Settings" Style="{StaticResource FlatButton}"
                                Click="OnSettingsClick" Margin="0,0,8,0"
                                ToolTip="Open settings"/>
                        <Button x:Name="WorkDirButton" Content="Folder" Style="{StaticResource FlatButton}"
                                Click="OnPickWorkDir" Margin="0,0,8,0"
                                ToolTip="Choose the working directory the agent operates in"/>
                        <Button x:Name="StartButton" Style="{StaticResource AccentButton}"
                                Click="OnStartClick" MinWidth="84">
                            <StackPanel Orientation="Horizontal">
                                <!-- Faint full ring + bright arc; the whole grid rotates while working -->
                                <Grid x:Name="ButtonSpinner" Width="13" Height="13" Margin="0,0,7,0"
                                      Visibility="Collapsed" VerticalAlignment="Center"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <RotateTransform Angle="0"/>
                                    </Grid.RenderTransform>
                                    <Ellipse Width="13" Height="13" Stroke="#59FFFFFF" StrokeThickness="2"/>
                                    <Ellipse Width="13" Height="13" Stroke="White" StrokeThickness="2"
                                             StrokeDashArray="5 16" StrokeDashCap="Round"/>
                                </Grid>
                                <TextBlock x:Name="StartButtonText" Text="Start" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Session strip: agent modes (left) + context/status/telemetry -->
            <Border Background="{StaticResource Bg}" BorderBrush="{StaticResource Border}"
                    BorderThickness="0,0,0,1" Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Agent behavior toggles -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="0,0,18,0">
                        <TextBlock Text="Plan" Foreground="{StaticResource TextDim}" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="PlanModeCombo" Style="{StaticResource DarkCombo}"
                                  MinWidth="84" VerticalAlignment="Center"
                                  SelectionChanged="OnPlanModeChanged"
                                  ToolTip="Plan Mode: have the agent plan and wait for your approval before making changes.&#x0a;Off = just do it. Ask = agent asks first. Auto = agent decides. Always = always plan first.">
                            <ComboBoxItem Content="Off"/>
                            <ComboBoxItem Content="Ask"/>
                            <ComboBoxItem Content="Auto"/>
                            <ComboBoxItem Content="Always"/>
                        </ComboBox>
                        <TextBlock Text="Perm" Foreground="{StaticResource TextDim}" FontSize="12"
                                   VerticalAlignment="Center" Margin="14,0,8,0"/>
                        <ComboBox x:Name="PermissionModeCombo" Style="{StaticResource DarkCombo}"
                                  MinWidth="90" VerticalAlignment="Center"
                                  SelectionChanged="OnPermissionModeChanged"
                                  ToolTip="Permission mode: Ask pauses for risky/unknown actions. Allow all lets the agent proceed without prompts.">
                            <ComboBoxItem Content="Ask"/>
                            <ComboBoxItem Content="Allow all"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Context usage -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Context" Foreground="{StaticResource TextDim}"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ProgressBar x:Name="ContextBar" Width="180" Style="{StaticResource UsageBar}"
                                     Value="0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ContextText" Text="-- / --"
                                   Foreground="{StaticResource TextDim}" FontSize="12"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Session telemetry -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TokensText" Text="Tokens: 0"
                                   Foreground="{StaticResource TextDim}" FontSize="12"/>
                        <TextBlock x:Name="CostText" Text="" Foreground="{StaticResource TextDim}"
                                   FontSize="12" Margin="14,0,0,0"/>
                        <Button x:Name="RepoButton" Style="{StaticResource FlatButton}"
                                Margin="14,0,0,0" Padding="10,3" FontSize="11"
                                Visibility="Collapsed" Click="OnRepoRefresh"
                                ToolTip="Git status (click to refresh)"/>
                        <Border Background="{StaticResource PanelAlt}" CornerRadius="6" Padding="8,2"
                                Margin="14,0,0,0">
                            <TextBlock x:Name="CompactText" Text="Auto-compact: on"
                                       Foreground="{StaticResource Ok}" FontSize="11"
                                       ToolTip="Conversation history is auto-summarized when it grows large"/>
                        </Border>
                        <Button x:Name="CompactButton" Content="Compact now" Style="{StaticResource FlatButton}"
                                Click="OnCompactClick" Margin="10,0,0,0" Padding="10,3" FontSize="11"
                                IsEnabled="False"
                                ToolTip="Summarize the conversation history now to free up context"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>

        <!-- Main area: Chats | Explorer | (Editor | Chat) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="HistoryCol" Width="220" MinWidth="0"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="ExplorerCol" Width="250" MinWidth="0"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Conversation history -->
            <Border Grid.Column="0" Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="10,8,8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Chats" Foreground="{StaticResource TextDim}" FontSize="12"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" x:Name="NewChatButton" Content="+ New"
                                Style="{StaticResource FlatButton}" Padding="8,2" FontSize="11"
                                Click="OnNewChat" IsEnabled="False"
                                ToolTip="Start a fresh conversation"/>
                    </Grid>

                    <ListBox x:Name="ConversationList" Grid.Row="1" Background="Transparent"
                             BorderThickness="0" Foreground="{StaticResource Text}"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="OnConversationSelected">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="Margin" Value="4,1"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="RowBorder" CornerRadius="7"
                                                    Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="RowBorder" Property="Background"
                                                            Value="{StaticResource PanelAlt}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="RowBorder" Property="Background"
                                                            Value="{StaticResource ToolBubble}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ConversationRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding DisplayTitle}"
                                                   Foreground="{StaticResource Text}" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Subtitle}"
                                                   Foreground="{StaticResource TextDim}" FontSize="10.5"
                                                   TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="&#x2715;" Tag="{Binding Id}"
                                            Style="{StaticResource FlatButton}" Padding="6,2" FontSize="10"
                                            VerticalAlignment="Center" Margin="6,0,0,0"
                                            Click="OnDeleteConversation"
                                            ToolTip="Delete this conversation"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="{StaticResource Border}"
                          Cursor="SizeWE" ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"
                          ToolTip="Drag to resize the chat history"/>

            <!-- File explorer -->
            <Border Grid.Column="2" Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="10,8,8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Explorer" Foreground="{StaticResource TextDim}" FontSize="12"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Refresh" Style="{StaticResource FlatButton}"
                                Padding="8,2" FontSize="11" Click="OnRefreshTree"
                                ToolTip="Rescan the working folder and git status"/>
                    </Grid>

                    <TreeView x:Name="FileTree" Grid.Row="1" Background="Transparent"
                              BorderThickness="0" Foreground="{StaticResource Text}"
                              MouseDoubleClick="OnTreeDoubleClick"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type models:FileNode}"
                                                      ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <TextBlock Text="{Binding Icon}" FontFamily="Segoe UI Emoji"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock x:Name="NameText" Text="{Binding Name}"
                                               VerticalAlignment="Center" Foreground="{StaticResource Text}"/>
                                    <TextBlock Text="{Binding StatusText}" FontSize="10" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="6,0,0,0"
                                               Foreground="{StaticResource Warn}"/>
                                </StackPanel>
                                <HierarchicalDataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="?">
                                        <Setter TargetName="NameText" Property="Foreground" Value="{StaticResource Ok}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="A">
                                        <Setter TargetName="NameText" Property="Foreground" Value="{StaticResource Ok}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="M">
                                        <Setter TargetName="NameText" Property="Foreground" Value="{StaticResource Warn}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="D">
                                        <Setter TargetName="NameText" Property="Foreground" Value="{StaticResource Err}"/>
                                    </DataTrigger>
                                </HierarchicalDataTemplate.Triggers>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="6" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="{StaticResource Border}"
                          Cursor="SizeWE" ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"
                          ToolTip="Drag to resize the explorer"/>

            <!-- Editor | Conversation -->
            <Grid Grid.Column="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="EditorCol" Width="0" MinWidth="0"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="240"/>
                </Grid.ColumnDefinitions>

                <!-- Code editor (hidden until a file is opened) -->
                <Border Grid.Column="0" Background="{StaticResource Bg}"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Background="{StaticResource Panel}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="EditorTitle" Text="" Foreground="{StaticResource Text}"
                                       FontSize="12" VerticalAlignment="Center" Margin="12,6"
                                       TextTrimming="CharacterEllipsis"/>
                            <Button x:Name="EditorSaveButton" Grid.Column="1" Content="Save"
                                    Style="{StaticResource FlatButton}" Padding="10,3" FontSize="11"
                                    Margin="0,4,6,4" Click="OnEditorSave" IsEnabled="False"
                                    ToolTip="Save (Ctrl+S)"/>
                            <Button Grid.Column="2" Content="&#x2715;" Style="{StaticResource FlatButton}"
                                    Padding="8,3" FontSize="11" Margin="0,4,8,4" Click="OnEditorClose"
                                    ToolTip="Close the editor"/>
                        </Grid>

                        <ae:TextEditor x:Name="CodeEditor" Grid.Row="1" ShowLineNumbers="True"
                                       FontFamily="Consolas" FontSize="13"
                                       Background="{StaticResource Bg}" Foreground="{StaticResource Text}"
                                       LineNumbersForeground="{StaticResource TextDim}"
                                       WordWrap="False"
                                       HorizontalScrollBarVisibility="Auto"
                                       VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>

                <GridSplitter x:Name="EditorSplitter" Grid.Column="1" Width="6" Visibility="Collapsed"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              Background="{StaticResource Border}" Cursor="SizeWE"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"
                              ToolTip="Drag to resize the editor"/>

                <!-- Conversation -->
                <ScrollViewer x:Name="ChatScroll" Grid.Column="2" VerticalScrollBarVisibility="Auto"
                      Padding="20,16" Background="{StaticResource Bg}">
            <ItemsControl x:Name="ChatList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ChatItem}">
                        <Border x:Name="Bubble" CornerRadius="10" Padding="14,10" Margin="0,6"
                                MaxWidth="820" HorizontalAlignment="Left"
                                Background="{StaticResource AgentBubble}"
                                BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <Grid>
                                <!-- Normal bubble: header + body (User/Agent/Tool/etc.) -->
                                <StackPanel x:Name="NormalPanel">
                                    <TextBlock x:Name="Hdr" Text="{Binding Header}"
                                               Foreground="{StaticResource TextDim}" FontSize="11"
                                               FontWeight="SemiBold" Margin="0,0,0,4"
                                               TextOptions.TextFormattingMode="Display"/>
                                    <TextBox Text="{Binding Text, Mode=OneWay}" IsReadOnly="True"
                                             x:Name="Body"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="{StaticResource Text}"
                                             TextWrapping="Wrap" Padding="0"
                                             IsTabStop="False"
                                             IsInactiveSelectionHighlightEnabled="True"
                                             Cursor="IBeam"
                                             PreviewMouseWheel="OnBodyMouseWheel"
                                             VerticalScrollBarVisibility="Disabled"
                                             HorizontalScrollBarVisibility="Disabled">
                                        <TextBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Command="Copy" Header="Copy"/>
                                                <MenuItem Command="SelectAll" Header="Select All"/>
                                            </ContextMenu>
                                        </TextBox.ContextMenu>
                                    </TextBox>
                                </StackPanel>

                                <!-- Reasoning: a Cursor-style collapsible "Thinking" block.
                                     Shown only for Thought items (see DataTriggers). -->
                                <Expander x:Name="ThoughtPanel" Visibility="Collapsed"
                                          IsExpanded="True" Foreground="{StaticResource TextDim}">
                                    <Expander.Header>
                                        <TextBlock Text="Thinking" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextDim}"
                                                   TextOptions.TextFormattingMode="Display"/>
                                    </Expander.Header>
                                    <TextBox Text="{Binding Text, Mode=OneWay}" IsReadOnly="True"
                                             x:Name="ThoughtBody"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="{StaticResource TextDim}" FontStyle="Italic"
                                             TextWrapping="Wrap" Padding="0,4,0,0"
                                             IsTabStop="False"
                                             IsInactiveSelectionHighlightEnabled="True"
                                             Cursor="IBeam"
                                             PreviewMouseWheel="OnBodyMouseWheel"
                                             VerticalScrollBarVisibility="Disabled"
                                             HorizontalScrollBarVisibility="Disabled">
                                        <TextBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Command="Copy" Header="Copy"/>
                                                <MenuItem Command="SelectAll" Header="Select All"/>
                                            </ContextMenu>
                                        </TextBox.ContextMenu>
                                    </TextBox>
                                </Expander>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding Role}" Value="User">
                                <Setter TargetName="Bubble" Property="Background" Value="{StaticResource UserBubble}"/>
                                <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Role}" Value="Thought">
                                <Setter TargetName="Bubble" Property="Background" Value="{StaticResource Panel}"/>
                                <Setter TargetName="NormalPanel" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="ThoughtPanel" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Role}" Value="Tool">
                                <Setter TargetName="Bubble" Property="Background" Value="{StaticResource ToolBubble}"/>
                                <Setter TargetName="Body" Property="FontFamily" Value="Consolas"/>
                                <Setter TargetName="Hdr" Property="Foreground" Value="{StaticResource Ok}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Role}" Value="Observation">
                                <Setter TargetName="Bubble" Property="Background" Value="{StaticResource Panel}"/>
                                <Setter TargetName="Body" Property="FontFamily" Value="Consolas"/>
                                <Setter TargetName="Body" Property="Foreground" Value="{StaticResource TextDim}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Role}" Value="Error">
                                <Setter TargetName="Bubble" Property="Background" Value="{StaticResource ErrBubble}"/>
                                <Setter TargetName="Hdr" Property="Foreground" Value="{StaticResource Err}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Role}" Value="System">
                                <Setter TargetName="Bubble" Property="Background" Value="{StaticResource Bg}"/>
                                <Setter TargetName="Bubble" Property="BorderThickness" Value="0"/>
                                <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Center"/>
                                <Setter TargetName="Body" Property="Foreground" Value="{StaticResource TextDim}"/>
                                <Setter TargetName="Hdr" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Draggable divider: resize the bottom dock (input + server log).
             Only meaningful while the log is expanded, so it is hidden until then. -->
        <GridSplitter x:Name="BottomSplitter" Grid.Row="2" Height="6" HorizontalAlignment="Stretch"
                      VerticalAlignment="Center" ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext" Cursor="SizeNS"
                      Background="{StaticResource Border}" Visibility="Collapsed"
                      ToolTip="Drag to resize the panel below (input + server log)"/>

        <!-- Bottom dock: model suggestions + approval banners + input + server log -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Model suggestion bar: one-click installs of better-suited models -->
            <Border x:Name="ModelSuggestionBar" Grid.Row="0" Visibility="Collapsed"
                    Background="{StaticResource PanelAlt}" BorderBrush="{StaticResource Accent}"
                    BorderThickness="0,2,0,0" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="Install a better-suited model"
                                   Foreground="{StaticResource Text}" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="One click installs it via the Model Store - no commands needed."
                                   Foreground="{StaticResource TextDim}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <!-- Install buttons are generated in code; Open Store / Dismiss are fixed -->
                    <StackPanel x:Name="ModelSuggestionButtons" Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Permission banner: shown when the agent pauses for risky-action approval -->
            <Border x:Name="PermissionApprovalBar" Grid.Row="1" Visibility="Collapsed"
                    Background="{StaticResource PanelAlt}" BorderBrush="{StaticResource Warn}"
                    BorderThickness="0,2,0,0" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Permission needed" Foreground="{StaticResource Text}"
                                   FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock x:Name="PermissionText"
                                   Text="The agent wants to perform an action that needs your approval."
                                   Foreground="{StaticResource TextDim}" FontSize="11"
                                   Margin="0,2,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PermissionDenyButton" Content="Deny"
                                Style="{StaticResource FlatButton}" Click="OnPermissionDeny" Margin="0,0,8,0"
                                ToolTip="Reject this action and tell the agent it was not allowed"/>
                        <Button x:Name="PermissionAllowButton" Content="Allow once"
                                Style="{StaticResource AccentButton}" Click="OnPermissionAllow" Margin="0,0,8,0"
                                ToolTip="Allow this pending action only"/>
                        <Button x:Name="PermissionAllowAllButton" Content="Allow all"
                                Style="{StaticResource FlatButton}" Click="OnPermissionAllowAll"
                                ToolTip="Allow all future actions in this session"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Plan approval banner: shown when the agent presents a plan and waits -->
            <Border x:Name="PlanApprovalBar" Grid.Row="2" Visibility="Collapsed"
                    Background="{StaticResource PanelAlt}" BorderBrush="{StaticResource Accent}"
                    BorderThickness="0,2,0,0" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Plan ready for your approval" Foreground="{StaticResource Text}"
                                   FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="Review the plan above, then approve to let the agent make the changes - or type what you want changed."
                                   Foreground="{StaticResource TextDim}" FontSize="11"
                                   Margin="0,2,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlanDenyButton" Content="Request changes"
                                Style="{StaticResource FlatButton}" Click="OnPlanDeny" Margin="0,0,8,0"
                                ToolTip="Reject the plan and tell the agent what to change"/>
                        <Button x:Name="PlanApproveButton" Content="Approve plan"
                                Style="{StaticResource AccentButton}" Click="OnPlanApprove"
                                ToolTip="Let the agent carry out the plan and make the changes"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Input -->
            <Border Grid.Row="3" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}"
                    BorderThickness="0,1,0,0" Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Attachment chips -->
                <WrapPanel x:Name="AttachPanel" Grid.Row="0" Orientation="Horizontal"
                           Margin="0,0,0,8" Visibility="Collapsed"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="AttachButton" Grid.Column="0" Content="+" Style="{StaticResource IconButton}"
                            Click="OnAttachClick" IsEnabled="False" Margin="0,0,8,0"
                            VerticalAlignment="Bottom"
                            ToolTip="Attach files, images or video (or drag &amp; drop / paste a screenshot)"/>

                    <Border Grid.Column="1" Background="{StaticResource PanelAlt}" CornerRadius="10"
                            BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="10,8"
                            AllowDrop="True" PreviewDragEnter="OnInputDragEnter"
                            PreviewDragOver="OnInputDragEnter" PreviewDrop="OnInputDrop">
                        <TextBox x:Name="InputBox" Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource Text}" CaretBrush="{StaticResource Text}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="160"
                                 VerticalScrollBarVisibility="Auto" FontSize="14"
                                 IsEnabled="False" AllowDrop="True"
                                 PreviewKeyDown="OnInputKeyDown"/>
                    </Border>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0"
                                VerticalAlignment="Bottom">
                        <TextBlock x:Name="QueueText" Text="" Foreground="{StaticResource Warn}"
                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"
                                   Visibility="Collapsed"
                                   ToolTip="Messages waiting to send after the agent finishes its current task"/>
                        <Button x:Name="InterruptButton" Content="Stop" Style="{StaticResource FlatButton}"
                                Click="OnInterruptClick" IsEnabled="False" Margin="0,0,8,0"
                                ToolTip="Stop the agent's current task (keeps the session running)"/>
                        <Button x:Name="SteerButton" Content="Steer" Style="{StaticResource FlatButton}"
                                Click="OnSteerClick" IsEnabled="False" Margin="0,0,8,0"
                                ToolTip="Interject a note immediately while the agent keeps working (skips the queue)"/>
                        <Button x:Name="SendButton" Content="Send" Style="{StaticResource AccentButton}"
                                Click="OnSendClick" IsEnabled="False"
                                ToolTip="Send now, or queue to send after the current task finishes (Enter)"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

            <!-- Log strip + model capabilities -->
            <Grid Grid.Row="4" Background="{StaticResource Panel}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Expander x:Name="ServerLogExpander" Grid.Column="0" Header="Server log"
                      Foreground="{StaticResource TextDim}"
                      Background="{StaticResource Panel}" Padding="12,4" IsExpanded="False"
                      Expanded="OnServerLogExpanded" Collapsed="OnServerLogCollapsed"
                      VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
                <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="LogBox" IsReadOnly="True" Background="{StaticResource Bg}"
                             Foreground="{StaticResource TextDim}" BorderThickness="0"
                             FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"/>
                </ScrollViewer>
            </Expander>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top"
                        Margin="12,6,14,0">
                <TextBlock Text="Capabilities" Foreground="{StaticResource TextDim}" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel x:Name="CapabilityPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
            </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
