<Window x:Class="StayVibin.ProviderSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StayVibin - Set up your AI provider" Width="520"
        SizeToContent="Height" MinHeight="480"
        Icon="Assets/stayvibin.png"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" FontSize="14"
        ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="Welcome to " Foreground="{StaticResource Text}"
                       FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="Stay" Foreground="{StaticResource Text}"
                       FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="Vibin" Foreground="{StaticResource Accent}"
                       FontSize="20" FontWeight="SemiBold"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Margin="0,0,0,16" TextWrapping="Wrap"
                   Foreground="{StaticResource TextDim}" FontSize="13"
                   Text="Pick the local AI provider and model the agent should use. You can change this later in Settings."/>

        <!-- Provider -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Provider" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
            <ComboBox x:Name="ProviderBox" Style="{StaticResource DarkCombo}" Height="32"/>
        </StackPanel>

        <!-- Ollama URL -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="Ollama URL" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
            <TextBox x:Name="UrlBox" Style="{StaticResource DarkInput}"/>
        </StackPanel>

        <!-- Model -->
        <StackPanel Grid.Row="4" Margin="0,0,0,8">
            <TextBlock Text="Model" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
            <TextBox x:Name="ModelBox" Style="{StaticResource DarkInput}"/>
        </StackPanel>

        <!-- Detected models + refresh -->
        <Grid Grid.Row="5" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="DetectedBox" Grid.Column="0" Style="{StaticResource DarkCombo}" Height="32"
                      SelectionChanged="OnDetectedSelected"
                      ToolTip="Models detected from your local Ollama"/>
            <Button x:Name="RefreshButton" Grid.Column="1" Content="Refresh"
                    Style="{StaticResource FlatButton}" Padding="12,4" Margin="8,0,0,0"
                    Click="OnRefresh"/>
        </Grid>

        <TextBlock Grid.Row="6" TextWrapping="Wrap" Foreground="{StaticResource TextDim}"
                   FontSize="12"
                   Text="Only Ollama is supported for now; more local providers (LM Studio, etc.) are coming later. Make sure Ollama is running and has at least one chat model pulled."/>

        <TextBlock x:Name="ErrorText" Grid.Row="7" Foreground="{StaticResource Err}" FontSize="12"
                   TextWrapping="Wrap" VerticalAlignment="Bottom" Visibility="Collapsed"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Style="{StaticResource FlatButton}" Padding="16,7"
                    Margin="0,0,10,0" Click="OnCancel"/>
            <Button Content="Save and continue" Style="{StaticResource AccentButton}" Padding="16,7"
                    Click="OnSave"/>
        </StackPanel>
    </Grid>
</Window>
